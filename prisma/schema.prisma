generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum WorkspaceRole {
  OWNER
  EDITOR
  VIEWER
}

enum ProposalStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMMITTED
}

enum VoteDecision {
  APPROVE
  REJECT
}

enum SyncStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum OperationType {
  CREATE_DOCUMENT
  UPDATE_DOCUMENT
  DELETE_DOCUMENT
  ARCHIVE_DOCUMENT
  RESTORE_DOCUMENT
}

enum ActivityAction {
  WORKSPACE_CREATED
  MEMBER_INVITED
  MEMBER_REMOVED
  MEMBER_ROLE_UPDATED
  DOCUMENT_CREATED
  DOCUMENT_UPDATED
  DOCUMENT_ARCHIVED
  DOCUMENT_RESTORED
  DOCUMENT_DELETED
  PROPOSAL_CREATED
  PROPOSAL_ACCEPTED
  PROPOSAL_REJECTED
  PROPOSAL_COMMITTED
  VERSION_RESTORED
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspaces       WorkspaceMember[]
  ownedWorkspaces  Workspace[]
  proposals        ChangeProposal[]
  votes            ProposalVote[]
  syncOperations   SyncOperation[]
  activityLogs     ActivityLog[]
  documentVersions DocumentVersion[]
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner       User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members     WorkspaceMember[]
  documents   Document[]
  proposals   ChangeProposal[]
  syncOps     SyncOperation[]
  activityLog ActivityLog[]

  @@index([ownerId])
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(VIEWER)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

model Document {
  id               String   @id @default(cuid())
  workspaceId      String
  title            String
  contentSnapshot  String   @default("")
  currentVersionId String?
  folderId         String?
  tags             String[]
  isArchived       Boolean  @default(false)
  createdById      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workspace Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  versions  DocumentVersion[]
  proposals ChangeProposal[]
  syncOps   SyncOperation[]

  @@index([workspaceId])
  @@index([workspaceId, isArchived])
  @@index([workspaceId, createdAt])
}

model DocumentVersion {
  id              String   @id @default(cuid())
  documentId      String
  versionNumber   Int
  contentSnapshot String
  patch           String?
  createdById     String
  createdAt       DateTime @default(now())

  document  Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdBy User     @relation(fields: [createdById], references: [id])

  proposals ChangeProposal[] @relation("BaseVersion")

  @@unique([documentId, versionNumber])
  @@index([documentId])
  @@index([documentId, versionNumber])
  @@index([documentId, createdAt])
}

model ChangeProposal {
  id            String         @id @default(cuid())
  documentId    String
  workspaceId   String
  authorId      String
  baseVersionId String?
  patch         String
  proposalType  String         @default("content_update")
  status        ProposalStatus @default(PENDING)
  committedAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  document    Document         @relation(fields: [documentId], references: [id], onDelete: Cascade)
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  author      User             @relation(fields: [authorId], references: [id])
  baseVersion DocumentVersion? @relation("BaseVersion", fields: [baseVersionId], references: [id])
  votes       ProposalVote[]

  @@index([workspaceId])
  @@index([documentId])
  @@index([workspaceId, status])
  @@index([workspaceId, createdAt])
}

model ProposalVote {
  id         String       @id @default(cuid())
  proposalId String
  userId     String
  decision   VoteDecision
  createdAt  DateTime     @default(now())

  proposal ChangeProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  user     User           @relation(fields: [userId], references: [id])

  @@unique([proposalId, userId])
  @@index([proposalId])
}

model SyncOperation {
  id              String        @id @default(cuid())
  documentId      String
  workspaceId     String
  userId          String
  operationType   OperationType
  payload         Json
  status          SyncStatus    @default(PENDING)
  retryCount      Int           @default(0)
  clientChecksum  String?
  operationId     String        @unique
  createdAt       DateTime      @default(now())
  processedAt     DateTime?

  document  Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id])

  @@index([workspaceId])
  @@index([documentId])
  @@index([userId, status])
  @@index([status, createdAt])
}

model ActivityLog {
  id          String         @id @default(cuid())
  workspaceId String
  userId      String
  action      ActivityAction
  entityType  String
  entityId    String
  metadata    Json?
  createdAt   DateTime       @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id])

  @@index([workspaceId])
  @@index([workspaceId, createdAt])
  @@index([userId])
}
