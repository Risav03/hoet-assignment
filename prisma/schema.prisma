generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String            @id @default(cuid())
  name            String
  email           String            @unique
  passwordHash    String
  avatarUrl       String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  activityLogs    ActivityLog[]
  syncOperations  SyncOperation[]
  ownedWorkspaces Workspace[]
  workspaces      WorkspaceMember[]
}

model Workspace {
  id          String            @id @default(cuid())
  name        String
  slug        String            @unique
  ownerId     String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  activityLog ActivityLog[]
  boards      Board[]
  documents   Document[]
  syncOps     SyncOperation[]
  owner       User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members     WorkspaceMember[]

  @@index([ownerId])
}

model Board {
  id            String          @id @default(cuid())
  workspaceId   String
  title         String
  isArchived    Boolean         @default(false)
  createdById   String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  workspace     Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  BoardEdge     BoardEdge[]
  BoardNode     BoardNode[]
  SyncOperation SyncOperation[]
  BoardVersion  BoardVersion[]

  @@index([workspaceId])
  @@index([workspaceId, createdAt])
  @@index([workspaceId, isArchived])
}

model BoardVersion {
  id            String   @id @default(cuid())
  boardId       String
  label         String?
  nodes         Json
  edges         Json
  createdById   String
  createdByName String
  createdAt     DateTime @default(now())
  board         Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@index([boardId, createdAt])
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(VIEWER)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

model SyncOperation {
  id             String        @id @default(cuid())
  workspaceId    String
  userId         String
  payload        Json
  status         SyncStatus    @default(PENDING)
  retryCount     Int           @default(0)
  clientChecksum String?
  operationId    String        @unique
  createdAt      DateTime      @default(now())
  processedAt    DateTime?
  boardId        String
  operationType  OperationType
  Board          Board         @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id])
  workspace      Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([boardId])
  @@index([userId, status])
  @@index([status, createdAt])
}

model ActivityLog {
  id          String         @id @default(cuid())
  workspaceId String
  userId      String
  entityType  String
  entityId    String
  metadata    Json?
  createdAt   DateTime       @default(now())
  action      ActivityAction
  user        User           @relation(fields: [userId], references: [id])
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, createdAt])
  @@index([userId])
}

model BoardEdge {
  id                                      String    @id
  boardId                                 String
  sourceId                                String
  targetId                                String
  label                                   String?
  createdAt                               DateTime  @default(now())
  Board                                   Board     @relation(fields: [boardId], references: [id], onDelete: Cascade)
  BoardNode_BoardEdge_sourceIdToBoardNode BoardNode @relation("BoardEdge_sourceIdToBoardNode", fields: [sourceId], references: [id], onDelete: Cascade)
  BoardNode_BoardEdge_targetIdToBoardNode BoardNode @relation("BoardEdge_targetIdToBoardNode", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([boardId, sourceId, targetId])
  @@index([boardId])
}

model BoardNode {
  id                                      String      @id
  boardId                                 String
  type                                    String
  x                                       Float
  y                                       Float
  width                                   Float       @default(200)
  height                                  Float       @default(120)
  content                                 Json
  createdAt                               DateTime    @default(now())
  updatedAt                               DateTime
  lastModifiedById                        String?
  lastModifiedByName                      String?
  BoardEdge_BoardEdge_sourceIdToBoardNode BoardEdge[] @relation("BoardEdge_sourceIdToBoardNode")
  BoardEdge_BoardEdge_targetIdToBoardNode BoardEdge[] @relation("BoardEdge_targetIdToBoardNode")
  Board                                   Board       @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@index([boardId])
}

enum WorkspaceRole {
  OWNER
  EDITOR
  VIEWER
}

enum SyncStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum OperationType {
  CREATE_BOARD
  DELETE_BOARD
  CREATE_NODE
  UPDATE_NODE
  MOVE_NODE
  DELETE_NODE
  CONNECT_NODES
  DISCONNECT_NODES
  DELETE_EDGE
}

enum ActivityAction {
  WORKSPACE_CREATED
  MEMBER_INVITED
  MEMBER_REMOVED
  MEMBER_ROLE_UPDATED
  BOARD_CREATED
  BOARD_UPDATED
  BOARD_ARCHIVED
  BOARD_DELETED
  NODE_CREATED
  NODE_UPDATED
  NODE_DELETED
  EDGE_CREATED
  EDGE_DELETED
}

// ── Document models ────────────────────────────────────────────────────────────

model Document {
  id          String             @id @default(cuid())
  workspaceId String
  ownerId     String
  title       String
  currentRev  Int                @default(0)
  isArchived  Boolean            @default(false)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  workspace   Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  ops         DocumentOp[]
  snapshots   DocumentSnapshot[]

  @@index([workspaceId])
  @@index([workspaceId, isArchived])
  @@index([workspaceId, createdAt])
}

model DocumentOp {
  id         String   @id @default(cuid())
  documentId String
  rev        Int
  clientId   String
  baseRev    Int
  /// Nullable: populated only for legacy diff-based ops (pre-OT migration)
  diff       Json?
  /// OT operation fields — populated for all ops after the OT migration
  opClientId String?
  type       String?
  position   Int?
  text       String?
  length     Int?
  createdAt  DateTime @default(now())
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId, rev])
  @@index([documentId, baseRev])
}

model DocumentSnapshot {
  id         String   @id @default(cuid())
  documentId String
  rev        Int
  content    Json
  createdAt  DateTime @default(now())
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId, rev])
}
